<?xml version="1.0" encoding="utf-8"?>
<navigation
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/homeFragment">

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.example.testandroid.ui.home.HomeFragment"
        android:label="Home"
        tools:layout="@layout/fragment_home">

        <action
            android:id="@+id/action_home_to_detail"
            app:destination="@id/detailFragment" />
        <action
            android:id="@+id/action_home_to_webview"
            app:destination="@id/webViewFragment" />
        <action
            android:id="@+id/action_home_to_preferences"
            app:destination="@id/preferencesFragment" />
    </fragment>

    <fragment
        android:id="@+id/detailFragment"
        android:name="com.example.testandroid.ui.detail.DetailFragment"
        android:label="Detail"
        tools:layout="@layout/fragment_detail">

        <argument
            android:name="itemData"
            app:argType="string"
            android:defaultValue="No data" />
    </fragment>

    <fragment
        android:id="@+id/webViewFragment"
        android:name="com.example.testandroid.ui.webview.WebViewFragment"
        android:label="WebView"
        tools:layout="@layout/fragment_webview" />

    <fragment
        android:id="@+id/preferencesFragment"
        android:name="com.example.testandroid.ui.preferences.PreferencesFragment"
        android:label="Preferences"
        tools:layout="@layout/fragment_preferences" />

</navigation>
